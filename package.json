{
  "name": "voiceos-backend",
  "version": "1.0.0",
  "description": "VoiceOS — Enterprise AI Telephony SaaS Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/jobs/workers/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/jobs/workers/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:reset": "prisma migrate reset",
    "generate-keys": "node scripts/generate-keys.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@deepgram/sdk": "^3.3.0",
    "@prisma/client": "^5.16.0",
    "@sendgrid/mail": "^8.1.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/ws": "^8.5.12",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "elevenlabs": "^0.15.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "groq-sdk": "^0.5.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.11.4",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "openai": "^4.52.7",
    "pdfjs-dist": "^4.4.168",
    "pino": "^9.3.1",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.1",
    "prisma": "^5.16.0",
    "puppeteer": "^22.13.1",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "stripe": "^16.2.0",
    "twilio": "^5.2.3",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.11",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitest/coverage-v8": "^2.0.3",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
