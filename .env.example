# =============================================================
# VoiceOS Backend — Environment Variables
# Copy this file to .env and fill in real values
# =============================================================

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://voiceos:voiceos_password@localhost:5432/voiceos_db?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── JWT (RSA-256) ───────────────────────────────────────────
# Generate with: npm run generate-keys
# Store as base64-encoded PEM strings
JWT_PRIVATE_KEY=base64_encoded_rsa_private_key_here
JWT_PUBLIC_KEY=base64_encoded_rsa_public_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# ─── Encryption ──────────────────────────────────────────────
ENCRYPTION_KEY=32_char_hex_encryption_key_here
ENCRYPTION_IV_LENGTH=16

# ─── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_twilio_api_secret_here
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# ─── Groq (LLM) ──────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.7

# ─── OpenAI (Embeddings) ─────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ─── Deepgram (STT) ──────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ─── ElevenLabs (TTS) ────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ─── AWS S3 ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=voiceos-recordings
AWS_S3_RECORDINGS_PREFIX=recordings/
AWS_S3_DOCUMENTS_PREFIX=documents/

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxx

# ─── SendGrid ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@voiceos.ai
SENDGRID_FROM_NAME=VoiceOS
SENDGRID_VERIFICATION_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxx
SENDGRID_RESET_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxx
SENDGRID_INVITE_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxx
SENDGRID_SUMMARY_TEMPLATE_ID=d-xxxxxxxxxxxxxxxxxxxx

# ─── Google Calendar ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google-calendar/callback

# ─── HubSpot ─────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_REDIRECT_URI=http://localhost:4000/api/v1/integrations/hubspot/callback

# ─── Salesforce ──────────────────────────────────────────────
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/salesforce/callback

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WEBHOOK_MAX=500

# ─── BullMQ ──────────────────────────────────────────────────
BULLMQ_PREFIX=voiceos
BULLMQ_MAX_RETRIES=3
BULLMQ_BACKOFF_DELAY=5000

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_CALL_RECORDING=true
ENABLE_TRANSCRIPTION=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_AUTO_SUMMARY=true
ENABLE_WEB_CRAWLER=true
MAX_CONCURRENT_CALLS=50
MAX_CALL_DURATION_SECONDS=3600
